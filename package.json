{
  "name": "calorie-tracker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun --watch server/index.ts",
    "dev:web": "cd web && bun run dev",
    "setup": "bun install && cd web && bun install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "concurrently": "^9.1.0"
  }
}
